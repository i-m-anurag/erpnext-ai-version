# Copy this file to ".env" (in this deploy/ folder) and fill in real values.
# Do NOT commit .env.
#
# Fully-qualified site name. ERPNext serves the site matching the Host header,
# so this should match the domain your nginx forwards.
SITE_NAME=erp.yourdomain.com

# MariaDB root password (used by the db container AND to create the site db).
DB_ROOT_PASSWORD=change-me-strong-root-pw

# ERPNext "Administrator" login password.
ADMIN_PASSWORD=change-me-strong-admin-pw

# --- Optional email routing (leave blank/omit for normal delivery) ---
# Approver AND this address both receive every email (monitor approvals):
# EMAIL_COPY_TO=ops@yourcompany.com
# ONLY this address receives email, real users get nothing (safe testing):
# EMAIL_REDIRECT_TO=staging-inbox@yourcompany.com
